{
  "db_name": "PostgreSQL",
  "query": "SELECT\n                p.id, p.username, p.name, p.comment, p.created_at, p.updated_at,\n                COUNT(t.track_id) as \"song_count!\",\n                0::bigint as \"duration!\"\n            FROM local_playlists p\n            LEFT JOIN local_playlist_tracks t ON p.id = t.playlist_id\n            WHERE p.id = $1\n            GROUP BY p.id",
